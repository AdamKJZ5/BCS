import { Request, Response } from "express";
import Invoice from "../models/Invoice";
import Lead from "../models/Lead";
import User from "../models/User";
import { AppError } from "../utils/AppError";
import asyncHandler from "../utils/asyncHandler";
import { createNotification, notifyAllAdmins } from "../utils/createNotification";
import { generateInvoicePDF } from "../utils/pdfGenerator";
import { loggers } from "../utils/logger";

/**
 * Create a new invoice
 */
export const createInvoice = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const {
      leadId,
      lineItems,
      taxRate = 0,
      dueDate,
      notes,
      internalNotes
    } = req.body;

    // Validate lead exists
    const lead = await Lead.findById(leadId);
    if (!lead) {
      throw new AppError("Lead not found", 404);
    }

    // Get customer from lead
    const customer = await User.findOne({ email: lead.email });
    if (!customer) {
      throw new AppError("Customer not found for this lead", 404);
    }

    // Calculate amounts
    const subtotal = lineItems.reduce(
      (sum: number, item: any) => sum + item.total,
      0
    );
    const taxAmount = (subtotal * taxRate) / 100;
    const total = subtotal + taxAmount;

    // Create invoice
    const invoice = await Invoice.create({
      leadId,
      customerId: customer._id,
      lineItems,
      subtotal,
      taxRate,
      taxAmount,
      total,
      amountPaid: 0,
      amountDue: total,
      dueDate,
      notes,
      internalNotes,
      status: "draft"
    });

    res.status(201).json({
      success: true,
      message: "Invoice created successfully",
      invoice
    });});

/**
 * Get all invoices (admin)
 */
export const getAllInvoices = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const page = Number(req.query.page) || 1;
    const limit = Number(req.query.limit) || 20;
    const skip = (page - 1) * limit;

    const { status, search, startDate, endDate, minAmount, maxAmount, sortBy, sortOrder } = req.query;

    // Build query
    const query: any = {};

    // Filter by status
    if (status && status !== "all") {
      query.status = status;
    }

    // Filter by date range
    if (startDate || endDate) {
      query.createdAt = {};
      if (startDate) {
        query.createdAt.$gte = new Date(startDate as string);
      }
      if (endDate) {
        const end = new Date(endDate as string);
        end.setHours(23, 59, 59, 999);
        query.createdAt.$lte = end;
      }
    }

    // Filter by amount range
    if (minAmount || maxAmount) {
      query.total = {};
      if (minAmount) {
        query.total.$gte = Number(minAmount);
      }
      if (maxAmount) {
        query.total.$lte = Number(maxAmount);
      }
    }

    // Search by invoice number or customer info
    if (search) {
      const searchRegex = new RegExp(search as string, "i");

      // Search invoice numbers directly
      const invoiceNumberMatch = await Invoice.find({
        ...query,
        invoiceNumber: searchRegex,
      })
        .populate("leadId", "name email phone")
        .populate("customerId", "name email")
        .lean();

      // Also search by customer name/email
      const allInvoices = await Invoice.find(query)
        .populate("leadId", "name email phone")
        .populate("customerId", "name email")
        .lean();

      const filteredInvoices = allInvoices.filter((inv: any) => {
        return (
          searchRegex.test(inv.invoiceNumber) ||
          (inv.customerId?.name && searchRegex.test(inv.customerId.name)) ||
          (inv.customerId?.email && searchRegex.test(inv.customerId.email)) ||
          (inv.leadId?.name && searchRegex.test(inv.leadId.name)) ||
          (inv.leadId?.email && searchRegex.test(inv.leadId.email))
        );
      });

      const total = filteredInvoices.length;

      // Apply sorting
      let sortField = sortBy as string || "createdAt";
      let sortDir = sortOrder === "asc" ? 1 : -1;

      filteredInvoices.sort((a: any, b: any) => {
        const aVal = a[sortField];
        const bVal = b[sortField];
        if (aVal < bVal) return -sortDir;
        if (aVal > bVal) return sortDir;
        return 0;
      });

      const paginatedInvoices = filteredInvoices.slice(skip, skip + limit);

      return res.json({
        success: true,
        data: paginatedInvoices,
        pagination: {
          total,
          page,
          pages: Math.ceil(total / limit),
        },
        filters: {
          search: search || "",
          status: status || "all",
          startDate: startDate || "",
          endDate: endDate || "",
          minAmount: minAmount || "",
          maxAmount: maxAmount || "",
          sortBy: sortBy || "createdAt",
          sortOrder: sortOrder || "desc",
        },
      });
    }

    // No search - standard query
    let sortOption: any = { createdAt: -1 };
    if (sortBy) {
      const sortDirection = sortOrder === "asc" ? 1 : -1;
      sortOption = { [sortBy as string]: sortDirection };
    }

    const [invoices, total] = await Promise.all([
      Invoice.find(query)
        .populate("leadId", "name email phone")
        .populate("customerId", "name email")
        .sort(sortOption)
        .skip(skip)
        .limit(limit)
        .lean(),
      Invoice.countDocuments(query)
    ]);

    res.json({
      success: true,
      data: invoices,
      pagination: {
        total,
        page,
        pages: Math.ceil(total / limit)
      },
      filters: {
        search: search || "",
        status: status || "all",
        startDate: startDate || "",
        endDate: endDate || "",
        minAmount: minAmount || "",
        maxAmount: maxAmount || "",
        sortBy: sortBy || "createdAt",
        sortOrder: sortOrder || "desc",
      },
    });});

/**
 * Get invoices for a specific lead (admin)
 */
export const getInvoicesByLead = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const { leadId } = req.params;

    const invoices = await Invoice.find({ leadId: leadId as any })
      .sort({ createdAt: -1 })
      .lean();

    res.json({
      success: true,
      invoices
    });});

/**
 * Get single invoice
 */
export const getInvoice = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const { id } = req.params;

    const invoice = await Invoice.findById(id)
      .populate("leadId", "name email phone damageDescription vehicleInfo")
      .populate("customerId", "name email phone")
      .lean();

    if (!invoice) {
      throw new AppError("Invoice not found", 404);
    }

    res.json({
      success: true,
      invoice
    });});

/**
 * Update invoice
 */
export const updateInvoice = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const { id } = req.params;
    const updates = req.body;

    const invoice = await Invoice.findById(id);
    if (!invoice) {
      throw new AppError("Invoice not found", 404);
    }

    // If line items changed, recalculate totals
    if (updates.lineItems || updates.taxRate !== undefined) {
      const lineItems = updates.lineItems || invoice.lineItems;
      const taxRate = updates.taxRate !== undefined ? updates.taxRate : invoice.taxRate;

      const subtotal = lineItems.reduce(
        (sum: number, item: any) => sum + item.total,
        0
      );
      const taxAmount = (subtotal * taxRate) / 100;
      const total = subtotal + taxAmount;

      updates.subtotal = subtotal;
      updates.taxAmount = taxAmount;
      updates.total = total;
      updates.amountDue = total - invoice.amountPaid;
    }

    Object.assign(invoice, updates);
    await invoice.save();

    res.json({
      success: true,
      message: "Invoice updated successfully",
      invoice
    });});

/**
 * Send invoice to customer (marks as sent)
 */
export const sendInvoice = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const { id } = req.params;

    const invoice = await Invoice.findById(id)
      .populate("leadId")
      .populate("customerId");

    if (!invoice) {
      throw new AppError("Invoice not found", 404);
    }

    // Update status to sent
    invoice.status = "sent";
    await invoice.save();

    // TODO: Send email with invoice
    // await sendInvoiceEmail(invoice);

    // Notify customer of new invoice
    try {
      const customerId = (invoice.customerId as any)._id || invoice.customerId;
      await createNotification({
        userId: customerId,
        type: "invoice",
        title: "New Invoice Received",
        message: `Invoice ${invoice.invoiceNumber} for $${invoice.total.toFixed(2)} is now available`,
        relatedInvoice: invoice._id,
        actionUrl: "/customer/dashboard",
      });
    } catch (notifError) {
      console.error("Failed to send invoice notification:", notifError);
    }

    res.json({
      success: true,
      message: "Invoice sent successfully",
      invoice
    });});

/**
 * Record payment for invoice
 */
export const recordPayment = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const { id } = req.params;
    const { amount, method, transactionId, notes } = req.body;

    const invoice = await Invoice.findById(id);
    if (!invoice) {
      throw new AppError("Invoice not found", 404);
    }

    if (amount <= 0) {
      throw new AppError("Payment amount must be greater than 0", 400);
    }

    if (amount > invoice.amountDue) {
      throw new AppError("Payment amount exceeds amount due", 400);
    }

    // Add payment to history
    invoice.payments.push({
      amount,
      method,
      transactionId,
      paidAt: new Date(),
      notes
    });

    // Update payment tracking
    invoice.amountPaid += amount;
    invoice.amountDue -= amount;

    // Update status
    if (invoice.amountDue === 0) {
      invoice.status = "paid";
      invoice.paidDate = new Date();
    } else if (invoice.amountPaid > 0) {
      invoice.status = "partially_paid";
    }

    await invoice.save();

    // Populate invoice for notifications
    const populatedInvoice = await Invoice.findById(invoice._id)
      .populate("customerId", "name email")
      .populate("leadId", "name");

    if (!populatedInvoice) {
      throw new AppError("Invoice not found after save", 500);
    }

    // Notify customer of payment confirmation
    try {
      const customerId = (populatedInvoice.customerId as any)._id || populatedInvoice.customerId;
      const statusMessage = invoice.status === "paid"
        ? "has been paid in full"
        : `received a payment of $${amount.toFixed(2)}`;

      await createNotification({
        userId: customerId,
        type: "payment",
        title: "Payment Confirmation",
        message: `Invoice ${populatedInvoice.invoiceNumber} ${statusMessage}`,
        relatedInvoice: populatedInvoice._id,
        actionUrl: "/customer/dashboard",
      });
    } catch (notifError) {
      console.error("Failed to send payment notification to customer:", notifError);
    }

    // Notify admins of payment received
    try {
      const customerName = (populatedInvoice.customerId as any).name || "Customer";
      const statusMessage = invoice.status === "paid"
        ? "paid in full"
        : `made a payment of $${amount.toFixed(2)}`;

      await notifyAllAdmins({
        type: "payment",
        title: "Payment Received",
        message: `${customerName} ${statusMessage} on invoice ${populatedInvoice.invoiceNumber}`,
        relatedInvoice: populatedInvoice._id,
      });
    } catch (notifError) {
      console.error("Failed to send payment notification to admins:", notifError);
    }

    res.json({
      success: true,
      message: "Payment recorded successfully",
      invoice
    });});

/**
 * Get customer's invoices
 */
export const getMyInvoices = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const userId = (req as any).user?.id;

    if (!userId) {
      throw new AppError("Not authenticated", 401);
    }

    const invoices = await Invoice.find({ customerId: userId })
      .populate("leadId", "damageDescription vehicleInfo")
      .sort({ createdAt: -1 })
      .lean();

    res.json({
      success: true,
      invoices
    });});

/**
 * Mark invoice as viewed by customer
 */
export const markInvoiceViewed = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const { id } = req.params;
    const userId = (req as any).user?.id;

    const invoice = await Invoice.findById(id);
    if (!invoice) {
      throw new AppError("Invoice not found", 404);
    }

    // Verify this invoice belongs to the user
    if (invoice.customerId.toString() !== userId) {
      throw new AppError("Not authorized to view this invoice", 403);
    }

    // Update status if it's currently "sent"
    if (invoice.status === "sent") {
      invoice.status = "viewed";
      await invoice.save();
    }

    res.json({
      success: true,
      invoice
    });});

/**
 * Delete invoice
 */
export const deleteInvoice = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const { id } = req.params;

    const invoice = await Invoice.findById(id);
    if (!invoice) {
      throw new AppError("Invoice not found", 404);
    }

    // Only allow deletion of draft invoices
    if (invoice.status !== "draft") {
      throw new AppError("Can only delete draft invoices", 400);
    }

    await Invoice.findByIdAndDelete(id);

    res.json({
      success: true,
      message: "Invoice deleted successfully"
    });});

/**
 * Get invoice statistics
 */
export const getInvoiceStats = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const now = new Date();
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
    const yearStart = new Date(now.getFullYear(), 0, 1);

    // Get all invoices
    const allInvoices = await Invoice.find({});

    // Calculate revenue statistics
    const totalRevenue = allInvoices
      .filter((inv) => inv.status === "paid")
      .reduce((sum, inv) => sum + inv.total, 0);

    const monthlyRevenue = allInvoices
      .filter((inv) =>
        inv.status === "paid" &&
        inv.paidDate &&
        new Date(inv.paidDate) >= monthStart
      )
      .reduce((sum, inv) => sum + inv.total, 0);

    const yearlyRevenue = allInvoices
      .filter((inv) =>
        inv.status === "paid" &&
        inv.paidDate &&
        new Date(inv.paidDate) >= yearStart
      )
      .reduce((sum, inv) => sum + inv.total, 0);

    const pendingAmount = allInvoices
      .filter((inv) => inv.status !== "paid" && inv.status !== "cancelled")
      .reduce((sum, inv) => sum + inv.amountDue, 0);

    const overdueAmount = allInvoices
      .filter((inv) => inv.status === "overdue")
      .reduce((sum, inv) => sum + inv.amountDue, 0);

    // Count by status
    const statusCounts = {
      draft: allInvoices.filter((inv) => inv.status === "draft").length,
      sent: allInvoices.filter((inv) => inv.status === "sent").length,
      viewed: allInvoices.filter((inv) => inv.status === "viewed").length,
      paid: allInvoices.filter((inv) => inv.status === "paid").length,
      partially_paid: allInvoices.filter((inv) => inv.status === "partially_paid").length,
      overdue: allInvoices.filter((inv) => inv.status === "overdue").length,
      cancelled: allInvoices.filter((inv) => inv.status === "cancelled").length,
    };

    // Count invoices by time period
    const todayCount = allInvoices.filter((inv) =>
      new Date(inv.createdAt) >= today
    ).length;

    const thisMonthCount = allInvoices.filter((inv) =>
      new Date(inv.createdAt) >= monthStart
    ).length;

    const thisYearCount = allInvoices.filter((inv) =>
      new Date(inv.createdAt) >= yearStart
    ).length;

    // Calculate average invoice value
    const paidInvoices = allInvoices.filter((inv) => inv.status === "paid");
    const averageInvoiceValue = paidInvoices.length > 0
      ? totalRevenue / paidInvoices.length
      : 0;

    res.json({
      total: allInvoices.length,
      byStatus: statusCounts,
      revenue: {
        total: totalRevenue,
        monthly: monthlyRevenue,
        yearly: yearlyRevenue,
        pending: pendingAmount,
        overdue: overdueAmount,
        averageInvoiceValue,
      },
      counts: {
        today: todayCount,
        thisMonth: thisMonthCount,
        thisYear: thisYearCount,
      },
    });});

/**
 * Download invoice as PDF
 */
export const downloadInvoicePDF = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const { id } = req.params;

    // Fetch invoice with populated customer data
    const invoice = await Invoice.findById(id).populate('customerId', 'name email phone');
    
    if (!invoice) {
      throw new AppError("Invoice not found", 404);
    }

    // Check authorization
    const userRole = (req as any).user?.role;
    const userId = (req as any).user?.id;

    if (userRole === 'customer' && invoice.customerId._id.toString() !== userId) {
      throw new AppError("Not authorized to access this invoice", 403);
    }

    // Generate PDF
    const pdfBuffer = await generateInvoicePDF(invoice as any);

    // Log PDF generation
    loggers.audit(
      'invoice_pdf_downloaded',
      userId || 'system',
      'Invoice',
      id,
      { invoiceNumber: invoice.invoiceNumber }
    );

    // Set response headers
    res.setHeader('Content-Type', 'application/pdf');
    res.setHeader(
      'Content-Disposition',
      `attachment; filename="Invoice-${invoice.invoiceNumber}.pdf"`
    );
    res.setHeader('Content-Length', pdfBuffer.length);

    // Send PDF
    res.send(pdfBuffer);
  } catch (error) {
    loggers.error('PDF generation failed', error as Error, {
      invoiceId: req.params.id
    });
    next(error);
  }
};

/**
 * Preview invoice PDF in browser
 */
export const previewInvoicePDF = asyncHandler(async (
  req: Request,
  res: Response
) => {
    const { id } = req.params;

    // Fetch invoice with populated customer data
    const invoice = await Invoice.findById(id).populate('customerId', 'name email phone');
    
    if (!invoice) {
      throw new AppError("Invoice not found", 404);
    }

    // Check authorization
    const userRole = (req as any).user?.role;
    const userId = (req as any).user?.id;

    if (userRole === 'customer' && invoice.customerId._id.toString() !== userId) {
      throw new AppError("Not authorized to access this invoice", 403);
    }

    // Generate PDF
    const pdfBuffer = await generateInvoicePDF(invoice as any);

    // Set response headers for inline viewing
    res.setHeader('Content-Type', 'application/pdf');
    res.setHeader(
      'Content-Disposition',
      `inline; filename="Invoice-${invoice.invoiceNumber}.pdf"`
    );
    res.setHeader('Content-Length', pdfBuffer.length);

    // Send PDF
    res.send(pdfBuffer);
  } catch (error) {
    loggers.error('PDF preview failed', error as Error, {
      invoiceId: req.params.id
    });
    next(error);
  }
};
