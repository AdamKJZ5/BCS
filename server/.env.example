NODE_ENV=development

# Server Configuration
PORT=5138

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/bellevue-collision
# For MongoDB Atlas (recommended for production):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/bellevue-collision?retryWrites=true&w=majority

# JWT Configuration (REQUIRED)
JWT_SECRET=your-super-secure-random-string-here-change-this-in-production
# Generate a secure secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Email Configuration (REQUIRED for lead notifications and customer signup)
# For Gmail: Use App Passwords (https://support.google.com/accounts/answer/185833)
# For other providers: Use your SMTP credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# CORS Configuration
# In production, set this to your frontend domain
CORS_ORIGIN=http://localhost:5137
# For production: CORS_ORIGIN=https://www.bellevuecollisionservices.com

# Base URL (REQUIRED for photo URLs and email links)
# This is the public URL where your server is accessible
BASE_URL=http://localhost:5138
# For production: BASE_URL=https://api.bellevuecollisionservices.com

# Stripe Payment Configuration (REQUIRED for invoice payments)
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Webhook Secret (REQUIRED for payment confirmations)
# Get this from: https://dashboard.stripe.com/webhooks
# Webhook endpoint: https://your-domain.com/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
