NODE_ENV=development

# Server Configuration
PORT=5000

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/autobody-leads

# Email Configuration (SMTP)
# You can use Gmail, SendGrid, Mailgun, etc.
# For Gmail: smtp.gmail.com, port 587, use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Business Email (where leads will be sent)
OWNER_EMAIL=shop-owner@example.com

# CORS Configuration
# In production, set this to your frontend domain (e.g., https://yourdomain.com)
# In development, use * to allow all origins
CORS_ORIGIN=*
