NODE_ENV=development

# Server Configuration
PORT=5138

# MongoDB Configuration
MONGO_URI=mongodb+srv://akjzoffices_db_user:YDIOixRNf1HgPCVC@demo.kj33rlz.mongodb.net/?appName=Demo
# Email Configuration (SMTP) - Using Resend
# Sign up at https://resend.com/ and create an API key
# Username is literally the word "resend"
# Password is your Resend API key (starts with re_)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here

# Business Email (where leads will be sent)
# This should be the email you verified in Resend
OWNER_EMAIL=your-verified-email@gmail.com

# Admin API Key (for protected admin routes)
ADMIN_API_KEY=your-secure-admin-key-change-this

# CORS Configuration
# In production, set this to your frontend domain (e.g., https://yourdomain.com)
# In development, set to your local frontend URL
CORS_ORIGIN=CORS_ORIGIN=https://www.bellevuecollisionservices.com


# JWT Configuration (REQUIRED)
JWT_SECRET=8ce0efba20f19eae8318cc8b0b2d21c5e77da584ee91cc56e75a6826f75b65b8402afed414cc6139a13883ff9658db3e05e127010624524442c63d7dc19b2199

# Base URL (REQUIRED for photo URLs and email links)
BASE_URL=http://localhost:5138

# Stripe Payment Configuration (REQUIRED for invoice payments)
# Get these from: https://dashboard.stripe.com/apikeys
# IMPORTANT: Replace these placeholder values with your actual Stripe keys
STRIPE_SECRET_KEY=sk_test_replace_with_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_publishable_key

# Stripe Webhook Secret (REQUIRED for payment confirmations)
# Get this after setting up webhook in Step 3 below
# Webhook endpoint will be: https://your-domain.com/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_replace_after_webhook_setup

